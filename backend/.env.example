# ── VirtualArtGallery — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored. Never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
DB_SA_PASSWORD=VagDev!Str0ng

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HMAC-SHA256
JWT_SECRET=ReplaceThisWithALongRandomSecretAtLeast32CharsLong!!

# ── Azure OpenAI (optional — AI features degrade gracefully if blank) ─────────
OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com/
OPENAI_API_KEY=your-azure-openai-api-key
OPENAI_DEPLOYMENT=gpt-4o

# ── Email (optional — logs in development if blank) ───────────────────────────
EMAIL_SMTP_HOST=smtp.sendgrid.net
EMAIL_SMTP_PORT=587
EMAIL_FROM=noreply@yourdomain.com
