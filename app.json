{
  "expo": {
    "name": "Virtual Art Gallery",
    "slug": "virtual-art-gallery",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#f5f5f4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.virtualartgallery.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to place artworks in your space using augmented reality.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to upload artwork images.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#8b5cf6"
      },
      "package": "com.virtualartgallery.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload artwork images."
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-sharing",
      "expo-web-browser"
    ],
    "scheme": "virtualartgallery",
    "extra": {
      "apiBaseUrl": "http://192.168.1.45:5005",
      "stripePublishableKey": "pk_test_placeholder"
    }
  }
}
